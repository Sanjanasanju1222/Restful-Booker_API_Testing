              "});\r",
              "\r",
              "\r",
              "//Assertion for the depositpaid\r",
              "pm.test(\"verify that the depositpaid is showing as expected or not\", function(){\r",
              "    pm.expect(pm.environment.get(\"dpaid\")).to.eql(responsebody.booking.depositpaid.toString());\r",
              "});\r",
              "\r",
              "//Assertion for the checkin\r",
              "pm.test(\"verify that the checkin is showing as expected or not\", function(){\r",
              "    pm.expect(pm.environment.get(\"checkin\")).to.eql(responsebody.booking.bookingdates.checkin);\r",
              "});\r",
              "\r",
