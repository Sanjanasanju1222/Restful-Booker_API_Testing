        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "//for generate firstname\r",
              "var firstname = pm.variables.replaceIn('{{$randomFirstName}}');\r",
              "console.log(firstname)\r",
              "pm.environment.set(\"fname\",firstname)\r",
              "\r",
              "//for generate lastname\r",
              "var lastname = pm.variables.replaceIn(\"{{$randomLastName}}\");\r",
              "console.log(lastname)\r",
              "pm.environment.set(\"lname\",lastname)\r",
              "\r",
              "//for generate totalprice\r",
              "var totalprice = pm.variables.replaceIn(\"{{$randomInt}}\");\r",
              "console.log(totalprice)\r",
              "pm.environment.set(\"tprice\",totalprice)\r",
              "\r",
              "//for generate depositpaid\r",
              "var depositpaid = pm.variables.replaceIn(\"{{$randomBoolean}}\");\r",
              "console.log(depositpaid)\r",
              "pm.environment.set(\"dpaid\",depositpaid)\r",
              "\r",
              "//for generate checkin data\r",
              "var checkin = require ('moment');\r",
              "console.log(checkin)\r",
              "\r",
              "var checkinData = checkin().format('YYYY-MM-DD');\r",
              "console.log(checkinData)\r",
              "pm.environment.set(\"checkin\",checkinData)\r",
              "\r",
              "//for generate checkout data\r",
              "\r",
              "var checkout = require ('moment');\r",
              "var checkoutData = checkout().add(5,'days').format('YYYY-MM-DD');\r",
              "pm.environment.set(\"checkout\",checkoutData)\r",
              "\r",
              "//for generate additionalneeds\r",
              "var additionalneeds = pm.variables.replaceIn('{{$randomColor}}');\r",
